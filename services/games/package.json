{
  "name": "@crash/games",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "start": "bun run src/main.ts",
    "test": "bun test tests/unit",
    "test:e2e": "bun --env-file=.env.test test tests/e2e",
    "migration:create": "mikro-orm migration:create",
    "migration:up": "mikro-orm migration:up"
  },
  "mikro-orm": {
    "configPaths": [
      "./src/infrastructure/persistence/mikro-orm.config.ts"
    ]
  },
  "dependencies": {
    "@crash/auth": "workspace:*",
    "@crash/contracts": "workspace:*",
    "@golevelup/nestjs-rabbitmq": "^5",
    "@mikro-orm/core": "6",
    "@mikro-orm/migrations": "6",
    "@mikro-orm/nestjs": "6",
    "@mikro-orm/postgresql": "6",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/websockets": "^11.1.27",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@mikro-orm/cli": "6",
    "bun-types": "latest",
    "typescript": "^5.8.3"
  }
}
